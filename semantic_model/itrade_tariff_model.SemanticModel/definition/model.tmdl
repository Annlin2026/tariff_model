model Model
    culture: en-US
    defaultPowerBIDataSourceVersion: powerBI_V3
    discourageImplicitMeasures: true
    sourceQueryCulture: en-US
    dataAccessOptions
        legacyRedirects
        returnErrorValuesAsNull

annotation __TEdtrTMDLDatabase__ = itrade_tariff_model

annotation DirectLakeBehavior = directLakeOnly

ref expression DatabaseQuery

ref table dim_country
ref table dim_country_partner
ref table dim_hs_code
ref table fact_tariff_rate
ref table dim_time_year

