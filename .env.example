# ==============================================================================
# iTrade 新平台 — Environment Variables Template
# ==============================================================================
#
# 1. 複製這個檔：`cp .env.example .env`
# 2. 打開 .env 逐一填值（.env 已在 .gitignore，不會 commit）
# 3. Live 測試前 source 一下：`set -a; source .env; set +a`
#    （或用 python-dotenv / IDE 內建自動載入）
#
# 沒填的變數會讓相關 test 自動 SKIP（不會炸）。Linux 上 pyadomd 不支援，
# tariff / market / product / industry 的 golden-CSV 類 test 無論 env 填不填
# 都會 SKIP，必須 Windows 才能跑 live。
# ==============================================================================


# ────────────────────────────────────────────
# [必填 × 6] Fabric 連線（跑任何 live test 都要）
# ────────────────────────────────────────────

# Azure Service Principal (Entra ID)
# 取得方式：Azure Portal → Microsoft Entra ID → App registrations → 選 SP → Overview
#   AZURE_TENANT_ID = SP 所屬 tenant 的 Directory ID（全組織共用）
#   AZURE_CLIENT_ID = SP 的 Application (client) ID（每個 SP 一個）
#   AZURE_CLIENT_SECRET = SP 的 client secret（Certificates & secrets 頁產生；有效期通常 6-24 月）
# 管理者：taitra.org.tw 的 Azure / Microsoft 365 admin
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Fabric Workspace IDs
# 取得方式：Fabric Portal → 選 workspace → Workspace settings → 複製 Workspace ID (GUID)
# 三個 workspace 通常由 Fabric admin 分三個環境建好
#   DEV  = 日常開發、PR 測試部署
#   UAT  = Phase 1 UAT 測試、業務驗收
#   PROD = 正式上線、對外服務
FABRIC_WORKSPACE_DEV=b20289d7-86a9-46f9-8603-60b58c69df07
FABRIC_WORKSPACE_UAT=76274d43-df88-49bb-93cf-b8fa66cb8ebe
FABRIC_WORKSPACE_PROD=8c1ee0e3-c023-455e-93e4-3a87619623de

# Fabric Deployment Pipeline (itrade-trade-pipeline)
# 三階段已綁好：Dev=DEV workspace / UAT=UAT workspace / Prod=PROD workspace
# 官方 promote API 路徑：POST /v1/deploymentPipelines/{id}/deploy
FABRIC_PIPELINE_ID=b2a9dab9-cd3b-491e-b4f1-d24684f55721


# ────────────────────────────────────────────
# [選填 × 2] Fabric SQL Warehouse（通常已填好）
# ────────────────────────────────────────────
# 從 Fabric Portal → Trade_Data_Warehouse → SQL analytics endpoint → Copy connection string
# 這組預設值跟 CLAUDE.md 文件一致，通常不用動
FABRIC_SQL_ENDPOINT=h2sgahquwqiuzfpg77jvxtcs2a-26eqfmvjq34unbqdmc2yy2o7a4.datawarehouse.fabric.microsoft.com
FABRIC_SQL_DATABASE=Trade_Data_Warehouse


# ────────────────────────────────────────────
# [選填 × 3] Windows-only 路徑 / 選項
# ────────────────────────────────────────────

# Tabular Editor 2/3 執行檔路徑（TMDL BPA 檢查用）
# 預設值是 Windows 標準安裝路徑；若自訂安裝位置在這裡覆蓋
# TABULAR_EDITOR_PATH=C:\Program Files (x86)\Tabular Editor\TabularEditor.exe

# Fabric Capacity SKU — 跑 perf 測試時會檢查
# 只有 F64+ 才能跑 P3 的 5×5×5 perf 基準（tests/tariff/test_tariff_5x5_country_hs_p50_F64.py）
# FABRIC_CAPACITY_SKU=

# Semantic model 實際名稱（已部署的 dataset name）
# 預設 = itrade_trade_model；如果在 workspace 改名了在這邊覆蓋
# SPIKE_MODEL_NAME=itrade_trade_model


# ────────────────────────────────────────────
# [不屬於本 repo 但 sibling project 會用] Teradata
# ────────────────────────────────────────────
# 如果你也要在 outer project（teradata-tradedata-to-fabric-warehouse）跑 Teradata
# 抽 data，以下變數在 outer project 的 .env 要填。本 repo 的 test **不用** Teradata。
# TERADATA_HOST=172.20.85.41
# TERADATA_PORT=1025
# TERADATA_USER=
# TERADATA_PASSWORD=
